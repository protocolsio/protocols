{"access":{"can_preview":true,"can_view":true,"can_edit":false,"can_remove":false,"can_add":false,"can_publish":false,"can_get_doi":false,"can_share":false,"can_share_organization":false,"can_move":false,"can_move_outside":false,"can_transfer":false,"can_download":true,"limited_run":false,"limited_private_links":false,"limited_blind_links":false,"is_locked":false},"acknowledgements":"","authors":[{"first_name":"Karen","last_name":"Guimaraes","affiliation":"Laboratório de Genética \u0026 Biodiversidade, Instituto de Ciências da Educação, Universidade Federal do Oeste do Pará, Santarém, Pará, Brazil","note":"","guid":"033D7B40F8CC11ED9D4302C0B41BC903","username":"karen-guimaraes","name":"Karen Guimaraes","affiliation_url":"","link":"","is_private_profile":false,"is_verified":true,"user_image_file":{"guid":"BDB913945B2A11EFA2EF0A58A9FEAC02","file_name":"bagu348e.jpg","url":"https://files.protocols.io/external/bagu348e-BDB913945B2A11EFA2EF0A58A9FEAC02.jpg","mime":"image/jpeg","size":27420,"width":0,"height":0,"avg_color":"","scan_status":0,"created_at":1723742460}}],"before_start":"{\"blocks\":[{\"key\":\"d0pvg\",\"text\":\" In microtubes containing tissue fragments, add 440μL of lysis buffer (10mM Tris-HCl, 2mM EDTA, 400mM NaCl, 2% SDS) and 10 µL of proteinase K (10mg/mL);\",\"type\":\"ordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"ce3fk\",\"text\":\" Incubate in a water bath at 55°C for approximately 1:30h or overnight;\",\"type\":\"ordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"2j22p\",\"text\":\" Add 300µL of NaCl (5M) and centrifuge for 10min at 10.000rpm.\",\"type\":\"ordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"dbnue\",\"text\":\" Transfer supernatant containing the DNA to microcentrifuge tube (1,5mL);\",\"type\":\"ordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"39ool\",\"text\":\" Add 500µl of 100% isopropanol. \",\"type\":\"ordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"2h9c1\",\"text\":\" Centrifuge for 10min at 10.000rpm;\",\"type\":\"ordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"9nr64\",\"text\":\" Discard the supernatant and reuse microcentrifuge tube;\",\"type\":\"ordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"6tee7\",\"text\":\" Add 700µL of 70% ethanol;\",\"type\":\"ordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"1p990\",\"text\":\" Centrifuge for 3min at 13.000rpm;\",\"type\":\"ordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"bqett\",\"text\":\" Discard the supernatant and dry microcentrifuge tube;\",\"type\":\"ordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}},{\"key\":\"evfg\",\"text\":\" Add sterile H2O and 5µL of RNAse (10mg/mL);\",\"type\":\"ordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[{\"style\":\"sub\",\"offset\":14,\"length\":1}],\"entityRanges\":[],\"data\":{}},{\"key\":\"2k76i\",\"text\":\" Incubate at 37°C for 30 min and stored at -20ºC. \",\"type\":\"ordered-list-item\",\"depth\":0,\"inlineStyleRanges\":[],\"entityRanges\":[],\"data\":{}}],\"entityMap\":{}}","book_chapter":null,"can_accept_authorship":false,"can_be_copied":true,"can_claim_authorship":false,"can_manage_keywords":true,"can_remove_fork":false,"can_sign":false,"child_steps":{},"cited_protocols":[],"collection_items":[],"created_on":1543244587,"creator":{"name":"Karen Guimaraes","first_name":"","last_name":"","affiliation":"Laboratório de Genética \u0026 Biodiversidade, Instituto de Ciências da Educação, Universidade Federal do Oeste do Pará, Santarém, Pará, Brazil","affiliation_url":"","username":"karen-guimaraes","